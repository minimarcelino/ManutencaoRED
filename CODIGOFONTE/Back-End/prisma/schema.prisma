generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model aluno {
  prontuario     String   @unique(map: "prontuario_UNIQUE") @db.VarChar(15)
  nome           String   @db.VarChar(60)
  dataNascimento DateTime @db.Date
  telefone       String   @unique(map: "telefone_UNIQUE") @db.VarChar(11)
  email          String   @unique(map: "email_UNIQUE") @db.VarChar(100)
  curso_idcurso  Int
  id             Int      @id @default(autoincrement())
  curso          curso    @relation(fields: [curso_idcurso], references: [idcurso], onDelete: NoAction, onUpdate: NoAction, map: "fk_aluno_curso")
  red            red[]

  @@index([curso_idcurso], map: "fk_aluno_curso_idx")
}

model curso {
  idcurso     Int           @id @default(autoincrement())
  sigla       String        @unique(map: "sigla_UNIQUE") @db.VarChar(15)
  nomeCurso   String        @unique(map: "nomeCurso_UNIQUE") @db.VarChar(60)
  coordenador Int
  aluno       aluno[]
  servidor    servidor      @relation(fields: [coordenador], references: [idservidor], onDelete: NoAction, onUpdate: NoAction, map: "fk_curso_servidor1")
  disciplinas disciplinas[]

  @@index([coordenador], map: "fk_curso_servidor1_idx")
}

model disciplinas {
  iddisciplinas  Int    @id @default(autoincrement())
  sigla          String @db.VarChar(15)
  nomeDisciplina String @db.VarChar(60)
  curso_idcurso  Int
  curso          curso  @relation(fields: [curso_idcurso], references: [idcurso], onDelete: NoAction, onUpdate: NoAction, map: "fk_disciplinas_curso1")
  pee            pee[]

  @@index([curso_idcurso], map: "fk_disciplinas_curso1_idx")
}

model pee {
  idpee                     Int            @id @default(autoincrement())
  situacao                  String         @db.VarChar(40)
  conteudo                  String         @db.Text
  metodologia               String         @db.Text
  trabalhos                 String         @db.Text
  bibliografia              String         @db.Text
  criterios                 String         @db.Text
  prazofinal                DateTime       @db.Date
  RED_idRED                 Int
  disciplinas_iddisciplinas Int
  canalComunicacao          String?        @db.VarChar(30)
  observacoes               String?        @db.Text
  dataEnvioProposta         DateTime?      @db.Date
  hash                      String?        @db.VarChar(64)
  avaliacaoAtividade        String?        @db.Text
  prazoEntregaAtividade     DateTime?      @db.Date
  dataEntregaAtividade      DateTime?      @db.Date
  cumpriuAtividade          String?        @db.VarChar(3)
  houveAvaliacao            String?        @db.VarChar(3)
  avaliacoesRealizadas      String?        @db.VarChar(3)
  dataAvaliacao             DateTime?      @db.Date
  percentualabono           Float
  red                       red            @relation(fields: [RED_idRED], references: [idRED], onDelete: NoAction, onUpdate: NoAction, map: "fk_pee_RED1")
  disciplinas               disciplinas    @relation(fields: [disciplinas_iddisciplinas], references: [iddisciplinas], onDelete: NoAction, onUpdate: NoAction, map: "fk_pee_disciplinas1")
  pee_servidor              pee_servidor[]

  @@index([RED_idRED], map: "fk_pee_RED1_idx")
  @@index([disciplinas_iddisciplinas], map: "fk_pee_disciplinas1_idx")
}

model arquivo {
  idArquivo Int    @id @default(autoincrement())
  path      String
  red_idRED Int
  red       red    @relation(fields: [red_idRED], references: [idRED], onDelete: NoAction, onUpdate: NoAction, map: "fk_arquivo_red")

  @@index([red_idRED], map: "idx_red_idRED")
}

model red {
  idRED               Int       @id @default(autoincrement())
  dataInicioProcesso  DateTime  @db.Date
  dataPrevisaoTermino DateTime  @db.Date
  motivoAfastamento   String    @db.Text
  situacao            String    @db.VarChar(40)
  coordenador         Int
  aluno_id            Int
  observacao          String?   @db.Text
  motivoRecusa        String?   @db.Text
  inicioAfastamento   DateTime  @db.Date
  tempoAfastamento    Int?
  semestreOuAnoAluno  Int?
  arquivos            arquivo[]
  pee                 pee[]
  aluno               aluno     @relation(fields: [aluno_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_RED_aluno1")
  servidor            servidor  @relation(fields: [coordenador], references: [idservidor], onDelete: NoAction, onUpdate: NoAction, map: "fk_RED_servidor1")

  @@index([aluno_id], map: "fk_RED_aluno1_idx")
  @@index([coordenador], map: "fk_RED_servidor1_idx")
}

model servidor {
  idservidor   Int            @id @default(autoincrement())
  email        String         @unique(map: "email_UNIQUE") @db.VarChar(60)
  tiposervidor String         @db.VarChar(15)
  senha        String         @db.VarChar(60)
  nome         String         @db.VarChar(60)
  prontuario   String         @unique(map: "prontuario_UNIQUE") @db.VarChar(15)
  token        String?        @db.VarChar(64)
  curso        curso[]
  pee_servidor pee_servidor[]
  red          red[]
}

model pee_servidor {
  id         Int      @id @default(autoincrement())
  peeId      Int
  servidorId Int
  pee        pee      @relation(fields: [peeId], references: [idpee])
  servidor   servidor @relation(fields: [servidorId], references: [idservidor])

  @@index([peeId], map: "peeId")
  @@index([servidorId], map: "servidorId")
}
